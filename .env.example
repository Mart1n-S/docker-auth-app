# ==========================================
# Fichier d'exemple des variables d'environnement
# Copiez ce fichier en le renommant '.env'
# et remplacez les valeurs par vos propres secrets.
# ==========================================

# Port d'écoute du serveur Node.js (par défaut: 3000)
PORT=3000

# Clé secrète pour générer et vérifier les tokens JWT
# Doit être une chaîne de caractères longue et complexe en production
JWT_SECRET=votre_cle_secrete_jwt_ici

# URI de connexion à MongoDB
# - En local avec Docker Compose : mongodb://mongo:27017/authdb
# - En local sans Docker : mongodb://localhost:27017/authdb
# - Sur Kubernetes (ReplicaSet) : mongodb://mongo-0.mongo:27017,mongo-1.mongo:27017,mongo-2.mongo:27017/authdb?replicaSet=rs0
MONGO_URI=mongodb://mongo:27017/authdb